  entity/.style={draw=ink, rounded corners=2pt, fill=paperbg, align=left, inner sep=4pt}]
\node[entity,fill=amber!18] (dept) {\textbf{DEPARTMENTS}\\ \underline{id} $\cdot$ name $\cdot$ description};
\node[entity,fill=amber!18, below=16mm of dept] (user) {\textbf{USERS}\\ \underline{id} $\cdot$ email $\cdot$ role\\ department\_id $\cdot$ is\_active};
\node[entity, right=34mm of dept] (doc) {\textbf{DOCUMENTS}\\ \underline{id} $\cdot$ filename\\ visibility $\cdot$ status\\ department\_id $\cdot$ uploaded\_by};
\node[entity, right=20mm of doc] (chunk) {\textbf{DOCUMENT\_CHUNKS}\\ \underline{id} $\cdot$ chunk\_index\\ child\_text $\cdot$ parent\_text\\ qdrant\_point\_id};
\node[entity, below=16mm of user] (sess) {\textbf{CHAT\_SESSIONS}\\ \underline{id} $\cdot$ user\_id $\cdot$ title};
\node[entity, right=22mm of sess] (msg) {\textbf{CHAT\_MESSAGES}\\ \underline{id} $\cdot$ session\_id\\ role $\cdot$ content $\cdot$ sources};
\node[entity, right=20mm of msg] (qlog) {\textbf{QUERY\_LOGS}\\ \underline{id} $\cdot$ query\_text\\ retrieval\_method\\ faithfulness\_score $\cdot$ answered};
